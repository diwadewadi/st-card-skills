{
  "name": "st-card-skills",
  "version": "3.10.0",
  "description": "SillyTavern character card & world book CLI + AI coding assistant skills (Claude Code, Codex, Gemini CLI)",
  "type": "module",
  "main": "dist/lib.js",
  "exports": {
    ".": "./dist/lib.js"
  },
  "bin": {
    "st-card-skills": "install.cjs",
    "st-card-tools": "dist/cli.js"
  },
  "files": [
    "commands",
    "templates",
    "devkit/package.json",
    "devkit/tsconfig.json",
    "devkit/webpack.config.ts",
    "devkit/postcss.config.js",
    "devkit/index.html",
    "devkit/API_INDEX.md",
    "devkit/types",
    "devkit/util",
    "devkit/templates",
    "install.cjs",
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "postinstall": "node install.cjs --auto"
  },
  "keywords": [
    "claude-code",
    "codex",
    "gemini",
    "sillytavern",
    "skills",
    "character-card",
    "world-book",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "crc": "^4.3.2",
    "playwright-core": "^1.59.1",
    "png-chunk-text": "^1.0.0",
    "png-chunks-extract": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  }
}
